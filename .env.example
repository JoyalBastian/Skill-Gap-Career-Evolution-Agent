# Copy to .env and adjust (do not commit .env)

DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# AI provider: gemini (Google API) or ollama (local, e.g. Docker)
AI_PROVIDER=gemini

# Docker only: start Ollama containers when AI_PROVIDER=ollama (leave empty for Gemini-only)
# COMPOSE_PROFILES=ollama

# Gemini (when AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLED=True
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-flash-latest

# Ollama (when AI_PROVIDER=ollama)
# Local runserver: http://localhost:11434  |  Docker web: set automatically to http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# Resume upload: set True to run full pipeline on upload (uses more API calls)
RUN_AI_PIPELINE_ON_RESUME=False

# SQLite path (relative to backend/); use db/db.sqlite3 in Docker
DATABASE_PATH=db.sqlite3
